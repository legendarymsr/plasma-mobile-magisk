#!/sbin/sh
# Magisk Module Installer — Plasma Mobile Theme + Launcher

SKIPUNZIP=1

ui_print() { echo "$1"; }
abort()     { ui_print "ERROR: $1"; exit 1; }

[ "$MAGISK_VER_CODE" -lt 20400 ] 2>/dev/null && {
  ui_print "! Magisk v20.4+ required"; exit 1
}

ui_print "- Plasma Mobile Theme + Launcher"
ui_print "  by legendarymsr"

unzip -o "$ZIPFILE" -x 'META-INF/*' -d "$MODPATH" >&2

# Create download-target directories customize.sh will populate
mkdir -p "$MODPATH/system/fonts"
mkdir -p "$MODPATH/system/media/wallpapers"

# Fonts and wallpapers: read-only
set_perm_recursive "$MODPATH/system/fonts"                   root root 0644 0644
set_perm_recursive "$MODPATH/system/media"                   root root 0644 0644
set_perm_recursive "$MODPATH/system/etc"                     root root 0644 0644

# Launcher APK: must be readable by PackageManager (priv-app)
set_perm_recursive "$MODPATH/system/priv-app"                root root 0755 0644

chmod 0755 "$MODPATH/service.sh"

ui_print "- Launcher installed: msr.plasma"

# Run post-extraction customization (font + wallpaper downloads)
. "$MODPATH/customize.sh"

ui_print "- Reboot, then set Plasma Mobile as your default home app."
