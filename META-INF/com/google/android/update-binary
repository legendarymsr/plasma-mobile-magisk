#!/sbin/sh
# Magisk Module Installer — Plasma Mobile Theme

SKIPUNZIP=1

ui_print() { echo "$1"; }
abort()     { ui_print "ERROR: $1"; exit 1; }

[ "$MAGISK_VER_CODE" -lt 20400 ] 2>/dev/null && {
  ui_print "! Magisk v20.4+ required"; exit 1
}

ui_print "- Plasma Mobile Theme"
ui_print "  by legendarymsr"

unzip -o "$ZIPFILE" -x 'META-INF/*' -d "$MODPATH" >&2

# Fonts and wallpapers are laid out under system/ — standard read permissions
set_perm_recursive "$MODPATH/system/fonts"          root root 0644 0644
set_perm_recursive "$MODPATH/system/media"          root root 0644 0644
set_perm_recursive "$MODPATH/system/etc/fonts"      root root 0644 0644
set_perm_recursive "$MODPATH/system/product/overlay" root root 0644 0644
chmod 0755 "$MODPATH/service.sh"

ui_print "- Done. Reboot to apply Plasma Mobile theme."
