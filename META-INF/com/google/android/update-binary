#!/sbin/sh
# Magisk Module Installer — Plasma Mobile Theme + Launcher

SKIPUNZIP=1

ui_print() { echo "$1"; }
abort()     { ui_print "ERROR: $1"; exit 1; }

[ "$MAGISK_VER_CODE" -lt 20400 ] 2>/dev/null && {
  ui_print "! Magisk v20.4+ required"; exit 1
}

ui_print "- Plasma Mobile Theme + Launcher"
ui_print "  by legendarymsr"

unzip -o "$ZIPFILE" -x 'META-INF/*' -d "$MODPATH" >&2

mkdir -p "$MODPATH/system/fonts"
mkdir -p "$MODPATH/system/media/wallpapers"
mkdir -p "$MODPATH/system/app"

# dirs need 0755 (not 0644) to be traversable
set_perm_recursive "$MODPATH/system/fonts"     root root 0755 0644
set_perm_recursive "$MODPATH/system/media"     root root 0755 0644
set_perm_recursive "$MODPATH/system/etc"       root root 0755 0644
set_perm_recursive "$MODPATH/system/priv-app"  root root 0755 0644
set_perm_recursive "$MODPATH/system/app"       root root 0755 0644

chmod 0755 "$MODPATH/service.sh"
[ -f "$MODPATH/action.sh" ] && chmod 0755 "$MODPATH/action.sh"

ui_print "- Plasma launcher installed"

. "$MODPATH/customize.sh"

ui_print "- Reboot to apply. Pick Plasma Mobile as home if prompted."
