<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Edge-to-edge launcher theme for Android 5+ (minSdk 21).

        windowTranslucentStatus / windowTranslucentNavigation tell the window
        manager to extend the layout behind the system bars rather than
        stopping at their edges. Combined with the systemUiVisibility flags
        and WindowInsetsController set in LauncherActivity.applyImmersive(),
        this achieves true full-bleed rendering on all API levels including
        Samsung One UI 7, which ignores WindowInsetsController alone on HOME
        activities.

        windowFullscreen hides the status bar from the theme side as a
        belt-and-suspenders measure; the bars are also hidden programmatically
        so they reappear only as transient overlays on swipe (IMMERSIVE_STICKY).
    -->
    <style name="Theme.PlasmaLauncher" parent="@android:style/Theme">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
